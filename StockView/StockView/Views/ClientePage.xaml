<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StockView.Views.ClientePage">

    <StackLayout Padding="20">
        <Entry x:Name="nombreEntry" Placeholder="Ingrese el cliente" />
        <StackLayout Orientation="Horizontal" HorizontalOptions="End" Margin="0,20,0,0">
            <Button Text="Cancelar" Clicked="Cancelar_Clicked" />
            <Button Text="OK" Clicked="OK_Clicked" />
        </StackLayout>
    </StackLayout>

</ContentPage>
